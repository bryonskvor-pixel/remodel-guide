  </ul>
  <button class="hamburger" id="hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
  <div class="mobile-menu" id="mobileMenu">
    <a href="/" onclick="closeMobile()">The Guides</a>
    <a href="/concierge" onclick="closeMobile()">The Concierge</a>
    <a href="/remi" onclick="closeMobile()">Meet Remi</a>
    <a href="https://remodelry.guide/remi" target="_blank" class="mobile-cta">Talk to Remi — It's Free</a>
  </div>
</nav>

<section class="blog-header">
