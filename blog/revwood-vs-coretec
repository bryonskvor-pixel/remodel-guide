<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>From the Field — remodel.guide</title>
  <meta name="description" content="Field-honest writing about remodeling — the products, decisions, and realities that showrooms and contractors don't explain. From the team behind remodel.guide." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="../assets/css/style.css">
  <style>
    .blog-header {
      background: var(--deep);
      padding: 120px 80px 80px;
      position: relative;
      overflow: hidden;
    }

    .blog-header::before {
      content: '';
      position: absolute;
      bottom: -200px; right: -200px;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(181,144,74,0.08) 0%, transparent 70%);
    }

    .blog-header-inner {
      max-width: 900px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .blog-header img.blog-masthead {
      width: 100%;
      border-radius: 12px;
      margin-bottom: 40px;
      display: block;
      max-height: 320px;
      object-fit: cover;
      object-position: center;
    }

    .blog-header h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(42px, 5vw, 64px);
      font-weight: 500;
      color: var(--white);
      margin-bottom: 16px;
      line-height: 1.1;
    }

    .blog-header p {
      font-size: 16px;
      font-weight: 300;
      color: rgba(255,255,255,0.55);
      max-width: 580px;
      line-height: 1.75;
    }

    .blog-grid {
      max-width: 900px;
      margin: 0 auto;
      padding: 80px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .post-card {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 40px;
      align-items: start;
      padding: 40px 0;
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .post-card:hover { opacity: 0.75; }
    .post-card:last-child { border-bottom: none; }

    .post-card-category {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--brass);
      margin-bottom: 10px;
      display: block;
    }

    .post-card h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px;
      font-weight: 500;
      color: var(--deep);
      line-height: 1.2;
      margin-bottom: 12px;
    }

    .post-card-deck {
      font-size: 14px;
      font-weight: 300;
      color: var(--slate);
      line-height: 1.7;
      max-width: 560px;
    }

    .post-card-link {
      font-size: 13px;
      font-weight: 500;
      color: var(--brass);
      margin-top: 16px;
      display: block;
    }

    .post-card-meta {
      text-align: right;
      flex-shrink: 0;
    }

    .post-card-tag {
      display: inline-block;
      background: var(--cream);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 400;
      color: var(--muted);
    }

    @media (max-width: 900px) {
      .blog-header { padding: 80px 24px 56px; }
      .blog-grid { padding: 48px 24px; }
      .post-card { grid-template-columns: 1fr; gap: 16px; }
      .post-card-meta { text-align: left; }
    }
  </style>
</head>
<body>

<nav>
  <a href="/" class="nav-logo">
    <img src="../assets/images/remodel-guide-logo.png" alt="remodel.guide">
  </a>
